:root {
    --bg-main: #0f172a;
    --bg-panel: #1e293b;
    --bg-accent: #334155;
    --primary: #6366f1;
    --primary-hover: #4f46e5;
    --accent: #10b981;
    --text-bright: #f8fafc;
    --text-muted: #94a3b8;
    --border: #334155;
    --danger: #ef4444;
}

.light-theme {
    --bg-main: #f1f5f9;
    --bg-panel: #ffffff;
    --bg-accent: #e2e8f0;
    --primary: #4f46e5;
    --primary-hover: #4338ca;
    --accent: #059669;
    --text-bright: #0f172a;
    --text-muted: #64748b;
    --border: #cbd5e1;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: var(--bg-main); color: var(--text-bright); min-height: 100vh; display: flex; flex-direction: column; }

/* Global Nav */
.navbar { height: 64px; background-color: var(--bg-panel); border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; padding: 0 1.5rem; position: sticky; top: 0; z-index: 100; }
.logo { display: flex; align-items: center; gap: 12px; font-weight: 700; font-size: 1.25rem; }
.logo-text span { font-size: 0.65rem; background: var(--primary); color: white; padding: 2px 6px; border-radius: 4px; vertical-align: middle; margin-left: 8px; }
.nav-links { display: flex; gap: 20px; }
.nav-links a { color: var(--text-muted); text-decoration: none; font-size: 0.9rem; font-weight: 500; transition: all 0.2s; }
.nav-links a:hover, .nav-links a.active { color: var(--primary); }
.theme-toggle { cursor: pointer; font-size: 1.2rem; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; border-radius: 50%; border: 1px solid var(--border); }

/* Hero Section */
.hero { height: 80vh; display: flex; align-items: center; justify-content: space-between; padding: 0 10%; background: radial-gradient(circle at 80% 20%, rgba(99, 102, 241, 0.15), transparent); }
.hero-content { max-width: 600px; }
.badge { display: inline-block; padding: 4px 12px; background: rgba(99, 102, 241, 0.2); color: var(--primary); border-radius: 20px; font-size: 0.75rem; font-weight: 700; margin-bottom: 1rem; }
.hero h1 { font-size: 3.5rem; line-height: 1.1; margin-bottom: 1.5rem; }
.text-gradient { background: linear-gradient(to right, #6366f1, #10b981); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
.hero p { font-size: 1.2rem; color: var(--text-muted); margin-bottom: 2rem; line-height: 1.6; }
.hero-btns { display: flex; gap: 15px; }
.btn-primary { background: var(--primary); color: white; padding: 12px 24px; border-radius: 8px; text-decoration: none; font-weight: 600; }
.btn-ghost { background: transparent; color: var(--text-muted); padding: 12px 24px; border: 1px solid var(--border); border-radius: 8px; text-decoration: none; }
.hero-visual { position: relative; width: 40%; height: 400px; }
.main-glow { position: absolute; inset: 0; background: var(--primary); filter: blur(100px); opacity: 0.2; border-radius: 50%; }
.floating-card { position: absolute; background: var(--bg-panel); padding: 15px 25px; border-radius: 12px; border: 1px solid var(--border); font-weight: 600; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); animation: float 3s ease-in-out infinite; }
.card-1 { top: 20%; left: 10%; animation-delay: 0s; }
.card-2 { top: 50%; right: 10%; animation-delay: 1s; }
.card-3 { bottom: 20%; left: 20%; animation-delay: 2s; }
@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-20px); } }

/* Features Grid */
.features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; padding: 5rem 10%; }
.feature-card { background: var(--bg-panel); padding: 2rem; border-radius: 20px; border: 1px solid var(--border); text-align: center; transition: transform 0.3s; }
.feature-card:hover { transform: translateY(-10px); border-color: var(--primary); }
.feat-icon { font-size: 2.5rem; margin-bottom: 1rem; }
.feat-link { color: var(--primary); text-decoration: none; font-weight: 600; }

/* Workbench Shared Layout */
.main-layout { display: grid; grid-template-columns: 320px 1fr 320px; flex: 1; overflow: hidden; }
.sidebar { background-color: var(--bg-panel); border-right: 1px solid var(--border); display: flex; flex-direction: column; gap: 1rem; padding: 1rem; overflow-y: auto; }
.sidebar.right { border-right: none; border-left: 1px solid var(--border); }
.widget { background: var(--bg-accent); border-radius: 12px; border: 1px solid var(--border); overflow: hidden; }
.widget-header { padding: 12px; font-size: 0.7rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; background: rgba(0,0,0,0.2); border-bottom: 1px solid var(--border); }
.scroll-area { padding: 10px; max-height: 250px; overflow-y: auto; }
.core-workbench { display: flex; flex-direction: column; background-color: var(--bg-main); }
.toolbar { height: 56px; background: var(--bg-panel); border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; padding: 0 1.5rem; }
.tool-group { display: flex; gap: 10px; }
.btn-tool { background: transparent; color: var(--text-muted); padding: 5px 12px; border: 1px solid var(--border); border-radius: 6px; cursor: pointer; font-size: 0.8rem; }
.status-pill { font-size: 0.75rem; padding: 4px 12px; background: var(--bg-main); border-radius: 20px; color: var(--text-muted); border: 1px solid var(--border); }
#editor-wrapper { height: 40%; border-bottom: 1px solid var(--border); }
.CodeMirror { height: 100% !important; font-family: 'Fira Code', monospace; font-size: 14px; }
.results-hub { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
.hub-tabs { display: flex; background: var(--bg-panel); border-bottom: 1px solid var(--border); }
.tab { padding: 12px 24px; cursor: pointer; border: none; background: none; color: var(--text-muted); font-size: 0.85rem; font-weight: 600; border-bottom: 3px solid transparent; }
.tab.active { color: var(--primary); border-bottom-color: var(--primary); background: rgba(99, 102, 241, 0.1); }
.tab-pane { display: none; flex: 1; overflow: hidden; flex-direction: column; padding: 1.5rem; }
.tab-pane.active { display: flex; }
.hub-toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
th { position: sticky; top: 0; background: var(--bg-panel); padding: 12px; text-align: left; border-bottom: 2px solid var(--border); color: var(--text-muted); }
td { padding: 10px 12px; border-bottom: 1px solid var(--border); }
.chart-container { flex: 1; position: relative; min-height: 350px; }

/* Notebook Layout */
.notebook-layout { display: flex; flex-direction: column; height: 100vh; }
.notebook-header { background: var(--bg-panel); padding: 1.5rem 2rem; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
.nb-title-input { background: transparent; border: none; font-size: 1.5rem; font-weight: 700; color: var(--text-bright); outline: none; }
.notebook-container { flex: 1; overflow-y: auto; padding: 2rem 15%; display: flex; flex-direction: column; gap: 2rem; }
.cell { background: var(--bg-panel); border-radius: 12px; border: 1px solid var(--border); overflow: hidden; box-shadow: var(--shadow); }
.cell-toolbar { padding: 8px 15px; background: rgba(0,0,0,0.2); display: flex; justify-content: space-between; align-items: center; font-size: 0.7rem; color: var(--text-muted); }
.text-editor { width: 100%; height: auto; min-height: 80px; background: transparent; border: none; color: var(--text-bright); padding: 15px; font-family: inherit; font-size: 1rem; outline: none; resize: none; }
.sql-editor { width: 100%; height: auto; }
.btn-run-cell { display: block; margin: 10px auto; padding: 6px 20px; background: var(--accent); color: white; border: none; border-radius: 6px; cursor: pointer; }
.cell-output { padding: 15px; border-top: 1px solid var(--border); background: var(--bg-main); }
.notebook-footer { padding: 1rem; background: var(--bg-panel); border-top: 1px solid var(--border); display: flex; justify-content: center; gap: 10px; }
.btn-danger-small { background: var(--danger); color: white; border: none; padding: 2px 6px; border-radius: 4px; cursor: pointer; font-size: 0.7rem; }

/* Academy, Diagnostics, About etc (Similar to v5) */
.academy-layout { padding: 4rem 10%; display: flex; flex-direction: column; gap: 3rem; }
.academy-header { text-align: center; max-width: 800px; margin: 0 auto; }
.progress-container { margin-top: 2rem; display: flex; align-items: center; gap: 15px; justify-content: center; }
.progress-bar { width: 300px; height: 10px; background: var(--bg-accent); border-radius: 5px; overflow: hidden; }
#prog-fill { height: 100%; background: var(--accent); transition: width 0.5s ease; }
.academy-grid { display: grid; grid-template-columns: 350px 1fr; gap: 2rem; }
.challenge-list { display: flex; flex-direction: column; gap: 10px; }
.chal-item { background: var(--bg-panel); padding: 15px; border-radius: 12px; border: 1px solid var(--border); cursor: pointer; }
.workspace-card { background: var(--bg-panel); padding: 2rem; border-radius: 20px; border: 1px solid var(--border); }
.diag-layout { padding: 4rem 10%; }
.diag-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; }
.diag-card { background: var(--bg-panel); padding: 2rem; border-radius: 20px; border: 1px solid var(--border); display: flex; flex-direction: column; gap: 1rem; }
.diag-out { margin-top: 1rem; padding: 15px; background: var(--bg-main); border-radius: 8px; font-size: 0.85rem; border: 1px solid var(--border); }
.about-layout { padding: 4rem 10%; }
.about-hero { text-align: center; padding: 4rem 0; background: linear-gradient(to bottom, rgba(99, 102, 241, 0.1), transparent); border-radius: 30px; margin-bottom: 4rem; }
.about-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 3rem; }
.about-card { background: var(--bg-panel); padding: 3rem; border-radius: 24px; border: 1px solid var(--border); }
.brand-links { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 2rem; }
.brand-item { padding: 15px; background: var(--bg-main); border-radius: 12px; border: 1px solid var(--border); }
.footer { background: var(--bg-panel); border-top: 1px solid var(--border); padding: 4rem 10% 2rem 10%; margin-top: auto; }
.footer-content { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 3rem; }
.footer-bottom { text-align: center; font-size: 0.8rem; color: var(--text-muted); border-top: 1px solid var(--border); padding-top: 2rem; }
